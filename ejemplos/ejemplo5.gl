// ejemplo5.gl - Comparaciones relacionales, modulo, modelar, docking, inferencia
// Cubre: >=, <=, %, modelar, docking, cadena inferida sin prefijo de tipo

lab Ejemplo5
/\
    // Comparaciones relacionales >= y <=
    muestra x : num = 10;
    muestra b : num = 10;
    muestra mayorOIgual : bool;
    muestra menorOIgual : bool;

    mayorOIgual = (x >= b);
    menorOIgual = (x <= b);

    // Operador modulo
    muestra resto : num;

    resto = (x % 3);

    // Cadena proteina inferida sin prefijo de tipo
    muestra protInferida : prot;

    protInferida = 'MKLV';

    // Mecanismo modelar sobre una proteina
    muestra modelo : prot;

    modelo = protInferida->modelar();

    // Mecanismo docking entre dos proteinas
    muestra sitio : prot = prot 'ACDE';

    sitio->docking(modelo);
\/
